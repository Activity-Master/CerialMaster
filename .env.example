# Environment variables align to rules/generative/platform/secrets-config/env-variables.md

# Application
ENVIRONMENT=dev
SERVICE_NAME=cerial-master
BASE_URL=http://localhost:8080
PORT=8080
REGION=local
STARTUP_CPU_BOOST=false

# Activity Master / database
DB_URL=jdbc:postgresql://localhost:5432/activitymaster
DB_USER=activitymaster
DB_PASS=change-me
DB_POOL_SIZE=10

# Auth / OIDC
OAUTH2_ISSUER_URL=https://auth.example.com/realms/activitymaster
OAUTH2_REALM=activitymaster
OAUTH2_CLIENT_ID=cerial-master
OAUTH2_CLIENT_SECRET=change-me
JWKS_URI=https://auth.example.com/realms/activitymaster/protocol/openid-connect/certs
INTROSPECTION_URL=https://auth.example.com/realms/activitymaster/protocol/openid-connect/token/introspect
AUTH_ADMIN_USER=admin
AUTH_ADMIN_PASS=change-me

# Cloud events
CLOUDEVENTS_FORMAT=application/cloudevents+json
CLOUDEVENTS_TRACE=false

# Observability
TRACING_ENABLED=false
LOGGING_BACKEND=cloud-logging
METRICS_EXPORT=enabled

# Testing
TEST_DB_CONTAINER_IMAGE=postgres:latest
SKIP_INTEGRATION_TESTS=false
ENABLE_DEBUG_LOGS=true

# Activity Master / Cerial Master defaults
ACTIVITYMASTER_ENTERPRISE_NAME=TestEnterprise
CERIAL_MASTER_SYSTEM_NAME=CerialMasterSystem
